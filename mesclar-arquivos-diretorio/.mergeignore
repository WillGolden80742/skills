# Diretórios e arquivos de sistema/build/dependências
node_modules/      # Módulos Node.js
.git/              # Repositório Git
dist/              # Diretório de build/distribuição
vendor/            # Dependências de terceiros (usado em PHP, Go, etc.)
build/             # Diretório de build geral
.next/             # Diretório de build do Next.js
.nuxt/             # Diretório de build do Nuxt.js
public/build/      # Outros diretórios de build comuns

# Arquivos de configuração e de controle de versão
.env               # Arquivos de variáveis de ambiente
.env.*             # Variações de arquivos de variáveis de ambiente
.gitignore         # O próprio .gitignore
.npmrc             # Configuração do NPM
.yarnrc            # Configuração do Yarn
package-lock.json  # Arquivo de lock do NPM (geralmente não incluído na mesclagem de código-fonte)
yarn.lock          # Arquivo de lock do Yarn (geralmente não incluído na mesclagem de código-source)
pnpm-lock.yaml     # Arquivo de lock do PNPM

# Arquivos temporários, de log e de banco de dados
*.db               # Arquivos de banco de dados (SQLite, etc.)
*.log              # Arquivos de log
*.tmp              # Arquivos temporários
temp/              # Diretório temporário
cache/             # Diretório de cache
tmp/               # Outro diretório temporário
uploads/temp/      # Diretório temporário dentro de uploads
storage/logs/      # Logs do Laravel
storage/framework/cache/ # Cache do Laravel

# Arquivos de imagem e mídia (comuns em projetos web)
*.svg              # Imagens SVG
*.png              # Imagens PNG
*.jpg              # Imagens JPG/JPEG
*.jpeg             # Imagens JPEG
*.gif              # Imagens GIF
*.bmp              # Imagens BMP
*.ico              # Ícones
*.webp             # Imagens WebP

# Outros tipos de arquivos gerados ou binários
*.map              # Source maps
*.min.js           # Arquivos JavaScript minificados (se não forem o código-fonte principal)
*.min.css          # Arquivos CSS minificados (se não forem o código-fonte principal)
*.xsd              # Arquivos de schema XML
Thumbs.db          # Cache de miniaturas do Windows
.DS_Store          # Arquivos de metadados do macOS
